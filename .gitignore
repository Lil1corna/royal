# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Local archives & duplicate trees (never commit)
Downloads/
*.zip
*-main/
*-main-*/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
/dist/

# production
/build/

# misc
.DS_Store
Thumbs.db
desktop.ini
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
.env.local
.env.production
.env.*.local

# vercel
.vercel

# supabase CLI local cache
supabase/.temp/

# netlify
.netlify/

# IDE
.idea/
.vscode/
.kiro/
.cursor/
.windsurf/

# turbo
.turbo/

# typescript
*.tsbuildinfo
next-env.d.ts

# local Playwright MCP / scratch screenshots (keep out of git)
.playwright-mcp/
