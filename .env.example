# ============================================================================
# Core app / deployment
# ============================================================================
# Public site origin. Example: https://your-site.netlify.app
NEXT_PUBLIC_SITE_URL=https://your-site.netlify.app

# ============================================================================
# Supabase (required)
# ============================================================================
# From Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only key for admin route handlers (never expose client-side)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Random 32+ character secret. Must match Supabase Edge Function env for
# verify-pending-payments (X-Cron-Secret) and NEXT app (verify-internal, callback).
CRON_SECRET=

# ============================================================================
# Upstash Redis (rate limiting — required for production payment/order safety)
# ============================================================================
# Create a free database at https://console.upstash.com
# Copy "REST URL" and "REST Token" from the database details page.
#
# Without these in production:
#   - Payment and order endpoints are FAIL-CLOSED (429 / deny).
#   - Other API routes still run (fail-open) but log [RATE_LIMIT] warnings.
# In local development, missing vars allow traffic so you can work offline.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============================================================================
# Kapital Bank Payment Gateway
# ============================================================================
# Obtained from Kapital Bank merchant portal (pg.kapitalbank.az)
KAPITAL_MERCHANT_ID=

# Convert cert/key to base64 (run in terminal):
#   base64 -i merchant.pem && base64 -i merchant.key
# Leave empty → MOCK MODE (safe for development without real certificates)
KAPITAL_CERT_BASE64=
KAPITAL_KEY_BASE64=

# false = TEST endpoint (tstpg.kapitalbank.az) — use during development
# true  = LIVE endpoint (txpg.kapitalbank.az)  — production only
KAPITAL_LIVE_MODE=false

# ============================================================================
# Delivery pricing (optional, has code defaults)
# ============================================================================
NEXT_PUBLIC_FREE_SHIPPING_FROM_AZN=200
NEXT_PUBLIC_COURIER_FEE_AZN=8

# ============================================================================
# Webhook integrations (optional)
# ============================================================================
DELIVERY_WEBHOOK_URL=https://example.com/webhook
DELIVERY_WEBHOOK_SECRET=your-webhook-secret

# ============================================================================
# Auth.js / NextAuth compatibility (optional in this project)
# ============================================================================
# This codebase uses Supabase Auth, not NextAuth. Keep these only if you add
# Auth.js/NextAuth integration in the future.
NEXTAUTH_URL=https://your-site.netlify.app
NEXTAUTH_SECRET=replace-with-random-32-plus-char-secret
AUTH_URL=https://your-site.netlify.app
AUTH_SECRET=replace-with-random-32-plus-char-secret

# ============================================================================
# Platform-provided vars (normally injected by Netlify/Vercel automatically)
# ============================================================================
# URL=https://your-site.netlify.app
# DEPLOY_PRIME_URL=https://deploy-preview-1--your-site.netlify.app
# DEPLOY_URL=https://deploy-preview-1--your-site.netlify.app
# VERCEL_URL=your-project.vercel.app

# ============================================================================
# Optional third-party OAuth keys (managed in Supabase provider settings)
# ============================================================================
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

